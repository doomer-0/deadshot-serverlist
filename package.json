{
    "name": "deadshot-serverlist",
    "version": "1.0.0",
    "description": "Server list for Deadshot.io",
    "main": "src/main.js",
    "scripts": {
        "start": "electron .",
        "dist-win": "electron-packager . deadshot-serverlist --platform=win32 --arch=x64 --out=../deadshot-serverlist-dist --overwrite --no-asar",
        "dist-linux": "electron-packager . deadshot-serverlist --platform=linux --arch=x64 --out=dist --overwrite --no-asar"
    },
    "devDependencies": {
        "electron": "^40.1.0",
        "@electron/packager": "^19.0.1"
    },
    "dependencies": {
        "ws": "^8.19.0"
    }
}